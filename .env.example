# ============================================================
# Multimodal RAG — Environment Configuration
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---- LLM ---------------------------------------------------
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024

# ---- Embeddings -------------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=64

# ---- Chunking ---------------------------------------------
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MIN_CHUNK_LENGTH=30

# ---- Retrieval --------------------------------------------
DEFAULT_TOP_K=5
HYBRID_ALPHA=0.5          # 1.0 = pure dense, 0.0 = pure BM25
ENABLE_RERANKING=true
ENABLE_QUERY_REWRITING=true
ENABLE_VERIFICATION=true

# ---- OCR ---------------------------------------------------
ENABLE_OCR=true
OCR_LANG=eng
OCR_DPI=300

# ---- Cache -------------------------------------------------
CACHE_ENABLED=true
CACHE_TTL=3600

# ---- Storage -----------------------------------------------
DATA_DIR=data
INDEX_DIR=data/indexes
RAW_DIR=data/raw

# ---- API ---------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
